{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dualexis.dev/schemas/semantic-event.json",
  "title": "DUALEXIS SemanticEvent",
  "description": "Wire-format JSON schema for semantic events crossing TB3 (edge to orchestrator). Raw media and identity fields are prohibited.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "event_type",
    "source",
    "zone_id",
    "timestamp",
    "confidence",
    "severity",
    "explanation",
    "privacy_level",
    "raw_media_persisted",
    "metadata"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique event identifier"
    },
    "event_type": {
      "type": "string",
      "enum": [
        "normal_flow",
        "crowd_acceleration",
        "exit_blockage",
        "audio_stress_signal",
        "fall_detected",
        "multimodal_conflict",
        "evacuation_signal",
        "unknown"
      ]
    },
    "source": {
      "type": "string",
      "enum": [
        "video_edge_node",
        "audio_edge_node",
        "sensor_node",
        "simulator",
        "manual_report"
      ]
    },
    "zone_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "severity": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "explanation": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2048
    },
    "privacy_level": {
      "type": "string",
      "enum": ["ephemeral", "semantic_only", "aggregated", "audit_only"]
    },
    "raw_media_persisted": {
      "type": "boolean",
      "const": false,
      "description": "Must remain false — DUALEXIS does not persist raw media by default"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "description": "String-only metadata map; forbidden keys rejected by L1 validators"
    }
  },
  "not": {
    "anyOf": [
      { "required": ["person_id"] },
      { "required": ["face_id"] },
      { "required": ["raw_video"] },
      { "required": ["raw_audio"] },
      { "required": ["image_data"] },
      { "required": ["voiceprint"] }
    ]
  }
}
