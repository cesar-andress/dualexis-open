# Local Orchestrator — L3 fusion, L4 graph, L5 reasoning, L6 recommendations.
FROM python:3.12-slim-bookworm

WORKDIR /app

COPY pyproject.toml uv.lock README.md ./
COPY dualexis ./dualexis
COPY apps ./apps

RUN pip install --no-cache-dir uv && uv sync --frozen --no-dev

ENV DUALEXIS_ENVIRONMENT=production
ENV PYTHONUNBUFFERED=1

CMD ["uv", "run", "python", "-m", "apps.orchestrator.main"]
