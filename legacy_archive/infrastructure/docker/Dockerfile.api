# REST API — control plane and dashboard backend (structured events only).
FROM python:3.12-slim-bookworm

WORKDIR /app

COPY pyproject.toml uv.lock README.md ./
COPY dualexis ./dualexis
COPY apps ./apps

RUN pip install --no-cache-dir uv && uv sync --frozen --no-dev

ENV DUALEXIS_ENVIRONMENT=production
ENV DUALEXIS_API_HOST=0.0.0.0
ENV DUALEXIS_API_PORT=8000
ENV PYTHONUNBUFFERED=1

EXPOSE 8000

CMD ["uv", "run", "python", "-m", "apps.api.main"]
