# DUALEXIS Docker Compose environment (copy to .env)

# Site identity
DUALEXIS_SITE_ID=site-local
DUALEXIS_NODE_ID=edge-001

# Event bus
DUALEXIS_NATS_URL=nats://nats:4222

# Edge processing
DUALEXIS_EDGE_BUFFER_TTL_SECONDS=30
DUALEXIS_ALLOW_PERSISTENT_MEDIA=false
DUALEXIS_ALLOW_BIOMETRIC_FEATURES=false

# API control plane
DUALEXIS_API_PORT=8000

# Optional central research server (leave empty to disable export)
DUALEXIS_RESEARCH_SERVER_URL=
DUALEXIS_RESEARCH_PORT=8001

# GPU (docker-compose.gpu.yml)
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DEVICE_COUNT=1

# Runtime
DUALEXIS_ENVIRONMENT=development
DUALEXIS_REASONING_ENABLED=true
