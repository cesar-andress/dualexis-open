digraph E2Leakage {
  rankdir=LR;
  node [shape=box, style=rounded];
  world_dynamics [label="world_dynamics\n(shared dynamics)"];
  metric_heuristic_emitter [label="event_generator\n(emission)"];
  ground_truth_rules [label="ground_truth_rules\n(labeling)"];
